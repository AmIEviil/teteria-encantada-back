# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=TeteriaEncantada
DB_USERNAME=postgres
DB_PASSWORD=

# --- Auth ---
JWT_SECRET=
JWT_EXPIRES_IN=8h

# --- App ---
FRONTEND_URL=http://localhost:5173
PORT=3000

# --- WhatsApp (Meta Cloud API) ---
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_TEMPLATE_NAME=reserva_recordatorio

# --- AWS S3 ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=teteria-encantada-dev
# Opcional: sobrescribe la base de la URL pública (CloudFront / endpoint custom).
# Si se omite, se usa https://<bucket>.s3.<region>.amazonaws.com
AWS_S3_PUBLIC_URL_BASE=

# Google OAuth2 (Fase 3)
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret
GOOGLE_CALLBACK_URL=https://tu-dominio/auth/google/callback
